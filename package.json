{
  "name": "nemoclaw",
  "version": "0.1.0",
  "description": "Hardened NemoClaw template for running OpenClaw inside OpenShell with scoped GitHub automation",
  "keywords": [
    "openclaw",
    "openshell",
    "sandbox",
    "automation",
    "security-hardening",
    "template"
  ],
  "license": "Apache-2.0",
  "bin": {
    "nemoclaw": "./bin/nemoclaw.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "prepublishOnly": "cd nemoclaw && npm install --ignore-scripts && npm run build"
  },
  "dependencies": {
    "openclaw": "2026.3.13"
  },
  "files": [
    "bin/",
    "nemoclaw/dist/",
    "nemoclaw/openclaw.plugin.json",
    "nemoclaw/package.json",
    "nemoclaw-blueprint/",
    "scripts/",
    "Dockerfile",
    ".dockerignore"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
