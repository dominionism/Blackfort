# Hardened defaults
NEMOCLAW_SECURITY_PROFILE=prod-secure
NEMOCLAW_ENABLE_PUBLIC_EDGE=0
NEMOCLAW_ENABLE_TELEGRAM=0
NEMOCLAW_ALLOW_INSECURE_DEMO_TUNNEL=0
NEMOCLAW_ALLOW_INSECURE_UI=0
NEMOCLAW_ENABLE_AUTO_PAIR=0
NEMOCLAW_ALLOW_PLAINTEXT_CREDENTIALS=0
NEMOCLAW_ENABLE_EXPERIMENTAL_LOCAL_INFERENCE=0

# Required only when your installer path downloads OpenShell
NEMOCLAW_OPENSHELL_SHA256=<expected-openshell-release-archive-sha256>

# Optional remote access mode
# NEMOCLAW_PUBLIC_EDGE_MODE=access-proxy
# NEMOCLAW_ACCESS_PROXY_URL=https://access.example.com

# Optional remote deploy host-key file
# NEMOCLAW_SSH_KNOWN_HOSTS=/path/to/known_hosts

# Do not put real secrets in this file if the repository is tracked.
# Prefer the local hidden prompts:
#   nemoclaw auth-nvidia
#   nemoclaw auth-github-worker
